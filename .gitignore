# Dependencies (regenerated by `npm install`)
node_modules/

# Runtime data — NEVER commit. server.js ensures defaults on first run.
# Contains: hashed passwords, cookie secret, employee records, interview answers.
data/*.json
data/.secret
data/interviews/*
!data/interviews/.gitkeep

# Generated documents per employee
outputs/*
!outputs/_company/
outputs/_company/*
!outputs/_company/.gitkeep

# Local backups (created by 3-BACKUP.bat)
backup/

# Distribution packages built by BUILD-PACKAGE.bat
HR-WWN-Package_*

# OS / editor junk
.DS_Store
*.swp
.vscode/
.idea/

# Logs
*.log
npm-debug.log*

# Temp files
*.tmp
.~lock.*
