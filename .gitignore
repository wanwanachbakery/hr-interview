# Dependencies (regenerated by `npm install`)
node_modules/

# ============================================================
# Runtime data — NEVER commit (contains password hashes, cookie
# signing secret, tenant data, interview answers, generated docs).
# server.js recreates the needed defaults on first run.
# ============================================================
# whole data dir except the folder structure markers
data/
# whole outputs dir except the _company marker
outputs/

# legacy single-tenant patterns (kept for safety)
data/*.json
data/.secret
data/_secret
data/_super_auth.json
data/_tenants.json
data/tenants/

# Local backups (created by 3-BACKUP.bat)
backup/

# Distribution packages / deploy artifacts
HR-Interview-Package_*
hr-interview-deploy.tar.gz
hr-interview-deploy.zip

# OS / editor junk
.DS_Store
*.swp
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
tmp-server.log

# Temp files
*.tmp
.~lock.*
